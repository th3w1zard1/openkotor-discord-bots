# Copy to repo-root `.env` (config package walks up from cwd) or export before `pnpm dev:trask`.
TRASK_DISCORD_APP_ID=
TRASK_DISCORD_PUBLIC_KEY=
TRASK_DISCORD_BOT_TOKEN=
# Optional single guild (fast slash registration). Ignored for deployment when TRASK_SLASH_GUILD_IDS is set.
TRASK_DISCORD_GUILD_ID=
# Comma-separated guild IDs where slash commands are registered (e.g. dev server + community server).
TRASK_SLASH_GUILD_IDS=
TRASK_ALLOWED_GUILD_IDS=
TRASK_APPROVED_CHANNEL_IDS=
# Headless GPT Researcher (same Python package as vendor/cli.py). No uvicorn / Web UI required.
# Defaults: discovers vendor/ai-researchwizard when cwd is the monorepo root; uses python on PATH.
TRASK_GPT_RESEARCHER_ROOT=
TRASK_GPT_RESEARCHER_PYTHON=python
# TRASK_GPT_RESEARCHER_SCRIPT=
TRASK_RESEARCHWIZARD_TIMEOUT_MS=120000
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
# Used for proactive semantic gate (override with a smaller embedding model if desired).
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# Optional: auto-replies in allowed channels without /ask (requires Message Content intent in Discord Developer Portal).
TRASK_PROACTIVE_ENABLED=0
TRASK_PROACTIVE_CHANNEL_IDS=
TRASK_PROACTIVE_DEBOUNCE_MS=25000
TRASK_PROACTIVE_USER_COOLDOWN_MS=120000
TRASK_PROACTIVE_COMPETING_MIN_LENGTH=80
TRASK_PROACTIVE_CLASSIFIER_MODEL=gpt-4o-mini
TRASK_PROACTIVE_CLASSIFIER_MIN_CONFIDENCE=0.55
TRASK_PROACTIVE_SIMILARITY_THRESHOLD=0.62
TRASK_PROACTIVE_MIN_MESSAGE_LENGTH=12
TRASK_PROACTIVE_MAX_MESSAGE_LENGTH=400
TRASK_PROACTIVE_MAX_REPLY_CHARS=650
INGEST_STATE_DIR=data/ingest-worker
