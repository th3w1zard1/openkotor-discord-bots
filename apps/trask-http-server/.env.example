# Port for Trask HTTP API + optional static Holocron web UI
TRASK_HTTP_PORT=4010

# Query history + data dir
TRASK_HTTP_DATA_DIR=data/trask-http-server

# Headless GPT Researcher — required for /api/trask/ask (runs trask_headless_research.py; no FastAPI UI)
TRASK_GPT_RESEARCHER_ROOT=
TRASK_GPT_RESEARCHER_PYTHON=python
TRASK_RESEARCHWIZARD_TIMEOUT_MS=120000

# Same ingest state dir as trask-bot / ingest-worker for /api/trask/sources policy view
INGEST_STATE_DIR=data/ingest-worker

# Browser origin(s) for CORS (Holocron dev server or GitHub Pages URL)
# TRASK_PUBLIC_WEB_ORIGIN=http://127.0.0.1:5173

# API key for Holocron web / SPA (Authorization: Bearer …). Omit only for local dev:
# TRASK_WEB_ALLOW_ANONYMOUS=1
# TRASK_WEB_API_KEY=change-me
TRASK_WEB_ALLOW_ANONYMOUS=1
TRASK_WEB_DEFAULT_USER_ID=qa-webui

# Optional static bundle (default: apps/holocron-web/dist)
# TRASK_WEBUI_DIST_PATH=

# Post-report rewrite (OpenRouter-compatible OpenAI SDK)
# OPENROUTER_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_CHAT_MODEL=openrouter/auto
# OPENROUTER_HTTP_REFERER=https://github.com/openkotor/openkotor-discord-bots
# OPENROUTER_APP_TITLE=OpenKotor Trask
# TRASK_REWRITE_MODEL_FALLBACKS=openai/gpt-4o-mini,meta-llama/llama-3.2-3b-instruct:free
