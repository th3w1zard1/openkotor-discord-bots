# Discord Application (Client) ID — same value as PAZAAK_DISCORD_APP_ID in the bot's .env.
# Required by the Embedded App SDK for the OAuth authorize flow.
VITE_DISCORD_CLIENT_ID=

# Optional comma-separated authoritative/fallback API origins. The first reachable origin is used
# for PazaakWorld REST calls. Example: https://api.example.com,https://pazaak-matchmaking.example.workers.dev
VITE_API_BASES=

# Optional Activity token exchange origin. Defaults to the first VITE_API_BASES origin, then same-origin.
# Useful when GitHub Pages hosts the Activity frontend and Cloudflare hosts /api/auth/token.
VITE_ACTIVITY_TOKEN_BASE=

# Optional Cloudflare Durable Object relay WebSocket base, e.g. wss://pazaak-matchmaking.example.workers.dev/relay.
# This relay carries Activity instance presence only; match actions remain on the authoritative Pazaak API.
VITE_ACTIVITY_RELAY_URL=
