# Managed AI and crawl services
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
FIRECRAWL_API_KEY=

# Shared persistence target
DATABASE_URL=postgres://postgres:postgres@localhost:5432/openkotor_bots

# Optional shared Discord target guild used by all three bots when per-bot guild ids are omitted
DISCORD_TARGET_GUILD_ID=

# Trask bot
TRASK_DISCORD_APP_ID=
TRASK_DISCORD_PUBLIC_KEY=
TRASK_DISCORD_BOT_TOKEN=
TRASK_DISCORD_GUILD_ID=
TRASK_ALLOWED_GUILD_IDS=
TRASK_APPROVED_CHANNEL_IDS=
TRASK_RESEARCHWIZARD_BASE_URL=http://localhost:8000
TRASK_RESEARCHWIZARD_API_KEY=
TRASK_RESEARCHWIZARD_TIMEOUT_MS=120000

# HK bot
HK_DISCORD_APP_ID=
HK_DISCORD_PUBLIC_KEY=
HK_DISCORD_BOT_TOKEN=
HK_DISCORD_GUILD_ID=

# Pazaak Bot
PAZAAK_DISCORD_APP_ID=
PAZAAK_DISCORD_PUBLIC_KEY=
PAZAAK_DISCORD_BOT_TOKEN=
PAZAAK_DISCORD_CLIENT_SECRET=
PAZAAK_DISCORD_GUILD_ID=
PAZAAK_DATA_DIR=data/pazaak-bot
PAZAAK_STARTING_CREDITS=1000
PAZAAK_DAILY_BONUS=200
PAZAAK_DAILY_COOLDOWN_MS=86400000
PAZAAK_TURN_TIMEOUT_MS=300000
# Port for the embedded HTTP/WebSocket API used by the Activity and browser
PAZAAK_API_PORT=4001
# Public URL where pazaak-world is hosted (used for the "Play in Browser" button)
PAZAAK_ACTIVITY_URL=https://openkotor.github.io/bots/pazaakworld
# Public standalone web URL used for OAuth landing/callback URL construction.
PAZAAK_PUBLIC_WEB_ORIGIN=https://openkotor.github.io/bots/pazaakworld
# Enables local synthetic Bearer tokens (dev-user-*) for browser-only testing.
PAZAAK_ALLOW_DEV_AUTH=false

# Standalone OAuth (PazaakWorld web sign-in)
# Discord defaults: if these are empty, the server falls back to
# PAZAAK_DISCORD_APP_ID and PAZAAK_DISCORD_CLIENT_SECRET when available.
PAZAAK_OAUTH_DISCORD_CLIENT_ID=
PAZAAK_OAUTH_DISCORD_CLIENT_SECRET=
PAZAAK_OAUTH_DISCORD_CALLBACK_URL=https://openkotor.github.io/bots/pazaakworld/api/auth/oauth/discord/callback

PAZAAK_OAUTH_GOOGLE_CLIENT_ID=
PAZAAK_OAUTH_GOOGLE_CLIENT_SECRET=
PAZAAK_OAUTH_GOOGLE_CALLBACK_URL=https://openkotor.github.io/bots/pazaakworld/api/auth/oauth/google/callback

PAZAAK_OAUTH_GITHUB_CLIENT_ID=
PAZAAK_OAUTH_GITHUB_CLIENT_SECRET=
PAZAAK_OAUTH_GITHUB_CALLBACK_URL=https://openkotor.github.io/bots/pazaakworld/api/auth/oauth/github/callback

# Ingest worker
INGEST_STATE_DIR=data/ingest-worker