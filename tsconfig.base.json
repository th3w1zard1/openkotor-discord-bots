{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "ES2023"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@openkotor/config": [
        "packages/config/src/index.ts"
      ],
      "@openkotor/core": [
        "packages/core/src/index.ts"
      ],
      "@openkotor/discord-ui": [
        "packages/discord-ui/src/index.ts"
      ],
      "@openkotor/pazaak-engine": [
        "packages/pazaak-engine/src/index.ts"
      ],
      "@openkotor/pazaak-engine/menu-preset": [
        "packages/pazaak-engine/src/menu-preset.ts"
      ],
      "@openkotor/pazaak-engine/opponents": [
        "packages/pazaak-engine/src/opponents.ts"
      ],
      "@openkotor/persistence": [
        "packages/persistence/src/index.ts"
      ],
      "@openkotor/personas": [
        "packages/personas/src/index.ts"
      ],
      "@openkotor/retrieval": [
        "packages/retrieval/src/index.ts"
      ]
    },
    "types": [
      "node"
    ],
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true
  }
}