# Slim regional proxy; build context = this directory (infra/matchmaking-inducer).
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=deps /app/node_modules ./node_modules
COPY package.json server.mjs ./
EXPOSE 8080
ENV PORT=8080
CMD ["node", "server.mjs"]
